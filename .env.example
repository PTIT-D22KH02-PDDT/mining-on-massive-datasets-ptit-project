# =============================================================================
# OTTO Recommender System — Environment Configuration Template
# =============================================================================

# --- Docker Hub Configuration ---
DOCKER_USERNAME=YOUR_DOCKERHUB_USERNAME
DOCKER_TAG=latest

# --- PostgreSQL Configuration ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=otto_recommender
POSTGRES_USER=otto
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis Configuration ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Kafka Configuration ---
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_HOST_EXTERNAL=localhost
KAFKA_PORT_EXTERNAL=29092

# --- API Configuration ---
API_URL=http://localhost:8000

# --- SASRec Model Configuration ---
SASREC_REMOTE_URL=https://rs-model1.vucongtuanduong.dpdns.org